/index.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/reportWebVitals.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/App.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/contexts/ThemeContext.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/utils/ScrollToTop.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/themeData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/index.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/pages/index.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/theme/theme.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Navbar/Navbar.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Footer/Footer.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Skills/Skills.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/About/About.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Landing/Landing.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Blog/Blog.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Education/Education.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Experience/Experience.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Testimonials/Testimonials.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Projects/Projects.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Projects/SingleProject/SingleProject.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Services/Services.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Blog/SingleBlog/SingleBlog.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Services/SingleService/SingleService.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/pages/Blog/BlogPage.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Contacts/Contacts.js",["189"],"import React, { useContext, useState } from \"react\";\nimport { Snackbar, IconButton, SnackbarContent } from \"@material-ui/core\";\nimport CloseIcon from \"@material-ui/icons/Close\";\nimport axios from \"axios\";\nimport isEmail from \"validator/lib/isEmail\";\nimport { makeStyles } from \"@material-ui/core/styles\";\nimport {\n  FaTwitter,\n  FaLinkedinIn,\n  FaGithub,\n  FaYoutube,\n  FaBloggerB,\n  FaRedditAlien,\n  FaStackOverflow,\n  FaCodepen,\n  FaInstagram,\n  FaGitlab,\n  FaMediumM,\n} from \"react-icons/fa\";\nimport { AiOutlineSend, AiOutlineCheckCircle } from \"react-icons/ai\";\nimport { FiPhone, FiAtSign } from \"react-icons/fi\";\nimport { HiOutlineLocationMarker } from \"react-icons/hi\";\n\nimport { ThemeContext } from \"../../contexts/ThemeContext\";\n\nimport { socialsData } from \"../../data/socialsData\";\nimport { contactsData } from \"../../data/contactsData\";\nimport \"./Contacts.css\";\n\nfunction Contacts() {\n  const [open, setOpen] = useState(false);\n\n  const [name, setName] = useState(\"\");\n  const [email, setEmail] = useState(\"\");\n  const [message, setMessage] = useState(\"\");\n\n  const [success, setSuccess] = useState(false);\n  const [errMsg, setErrMsg] = useState(\"\");\n\n  const { theme } = useContext(ThemeContext);\n\n  const handleClose = (event, reason) => {\n    if (reason === \"clickaway\") {\n      return;\n    }\n\n    setOpen(false);\n  };\n\n  const useStyles = makeStyles((t) => ({\n    input: {\n      border: `4px solid ${theme.primary80}`,\n      backgroundColor: `${theme.secondary}`,\n      color: `${theme.tertiary}`,\n      fontFamily: \"var(--primaryFont)\",\n      fontWeight: 500,\n      transition: \"border 0.2s ease-in-out\",\n      \"&:focus\": {\n        border: `4px solid ${theme.primary600}`,\n      },\n    },\n    message: {\n      border: `4px solid ${theme.primary80}`,\n      backgroundColor: `${theme.secondary}`,\n      color: `${theme.tertiary}`,\n      fontFamily: \"var(--primaryFont)\",\n      fontWeight: 500,\n      transition: \"border 0.2s ease-in-out\",\n      \"&:focus\": {\n        border: `4px solid ${theme.primary600}`,\n      },\n    },\n    label: {\n      backgroundColor: `${theme.secondary}`,\n      color: `${theme.primary}`,\n      fontFamily: \"var(--primaryFont)\",\n      fontWeight: 600,\n      fontSize: \"0.9rem\",\n      padding: \"0 5px\",\n      transform: \"translate(25px,50%)\",\n      display: \"inline-flex\",\n    },\n    socialIcon: {\n      width: \"45px\",\n      height: \"45px\",\n      borderRadius: \"50%\",\n      display: \"flex\",\n      alignItems: \"center\",\n      justifyContent: \"center\",\n      fontSize: \"21px\",\n      backgroundColor: theme.primary,\n      color: theme.secondary,\n      transition: \"250ms ease-in-out\",\n      \"&:hover\": {\n        transform: \"scale(1.1)\",\n        color: theme.secondary,\n        backgroundColor: theme.tertiary,\n      },\n    },\n    detailsIcon: {\n      backgroundColor: theme.primary,\n      color: theme.secondary,\n      borderRadius: \"50%\",\n      width: \"45px\",\n      height: \"45px\",\n      display: \"flex\",\n      alignItems: \"center\",\n      justifyContent: \"center\",\n      fontSize: \"23px\",\n      transition: \"250ms ease-in-out\",\n      flexShrink: 0,\n      \"&:hover\": {\n        transform: \"scale(1.1)\",\n        color: theme.secondary,\n        backgroundColor: theme.tertiary,\n      },\n    },\n    submitBtn: {\n      backgroundColor: theme.primary,\n      color: theme.secondary,\n      transition: \"250ms ease-in-out\",\n      \"&:hover\": {\n        transform: \"scale(1.08)\",\n        color: theme.secondary,\n        backgroundColor: theme.tertiary,\n      },\n    },\n  }));\n\n  const classes = useStyles();\n  const [isLoading, setIsLoading] = useState(false);\n  //Sending data to the node server to email\n\n  //   const handleContactForm = async (e) => {\n  //     e.preventDefault();\n\n  //     if (name && email && message) {\n  //       if (isEmail(email)) {\n  //         setIsLoading(true); // Show loading indicator\n  //         try {\n  //           const responseData = { name, email, message };\n  //           await axios.post(\"http://localhost:5001/send-email\", responseData); // Update to your backend URL\n  //           console.log(\"Form submitted successfully!\");\n  //           setSuccess(true);\n  //           setErrMsg(\"\");\n  //           setName(\"\");\n  //           setEmail(\"\");\n  //           setMessage(\"\");\n  //           setOpen(false);\n  //         } catch (error) {\n  //           console.error(\"Error submitting form:\", error);\n  //           setErrMsg(\"Submission failed. Please try again later.\");\n  //           setOpen(true);\n  //         } finally {\n  //           setIsLoading(false); // Hide loading indicator\n  //         }\n  //       } else {\n  //         setErrMsg(\"Invalid email format\");\n  //         setOpen(true);\n  //       }\n  //     } else {\n  //       setErrMsg(\"All fields are required\");\n  //       setOpen(true);\n  //     }\n  //   };\n\n  //Sending to google sheets\n  const handleContactForm = async (e) => {\n    e.preventDefault();\n\n    if (name && email && message) {\n      if (isEmail(email)) {\n        setIsLoading(true); // Show loading indicator\n        try {\n          const responseData = { name, email, message };\n          await axios.post(contactsData.sheetAPI, responseData);\n          console.log(\"Form submitted successfully!\");\n          setSuccess(true);\n          setErrMsg(\"\");\n          setName(\"\");\n          setEmail(\"\");\n          setMessage(\"\");\n          setOpen(false);\n        } catch (error) {\n          console.error(\"Error submitting form:\", error);\n          setErrMsg(\"Submission failed. Please try again later.\");\n          setOpen(true);\n        } finally {\n          setIsLoading(false); // Hide loading indicator\n        }\n      } else {\n        setErrMsg(\"Invalid email format\");\n        setOpen(true);\n      }\n    } else {\n      setErrMsg(\"All fields are required\");\n      setOpen(true);\n    }\n  };\n\n  //Old approach data sending to google sheets\n\n  //   const handleContactForm = (e) => {\n  //     e.preventDefault();\n\n  //     if (name && email && message) {\n  //       if (isEmail(email)) {\n  //         const responseData = {\n  //           name: name,\n  //           email: email,\n  //           message: message,\n  //         };\n\n  //         axios.post(contactsData.sheetAPI, responseData).then((res) => {\n  //           console.log(\"success\");\n  //           setSuccess(true);\n  //           setErrMsg(\"\");\n\n  //           setName(\"\");\n  //           setEmail(\"\");\n  //           setMessage(\"\");\n  //           setOpen(false);\n  //         });\n  //       } else {\n  //         setErrMsg(\"Invalid email\");\n  //         setOpen(true);\n  //       }\n  //     } else {\n  //       setErrMsg(\"Enter all the fields\");\n  //       setOpen(true);\n  //     }\n  //   };\n\n  return (\n    <div\n      className=\"contacts\"\n      id=\"contacts\"\n      style={{ backgroundColor: theme.secondary }}\n    >\n      <div className=\"contacts--container\">\n        <h1 style={{ color: theme.primary }}>Contacts</h1>\n        <div className=\"contacts-body\">\n          <div className=\"contacts-form\">\n            <form onSubmit={handleContactForm}>\n              <div className=\"input-container\">\n                <label htmlFor=\"Name\" className={classes.label}>\n                  Name\n                </label>\n                <input\n                  placeholder=\"Name\"\n                  value={name}\n                  onChange={(e) => setName(e.target.value)}\n                  type=\"text\"\n                  name=\"Name\"\n                  className={`form-input ${classes.input}`}\n                />\n              </div>\n              <div className=\"input-container\">\n                <label htmlFor=\"Email\" className={classes.label}>\n                  Email\n                </label>\n                <input\n                  placeholder=\"Email\"\n                  value={email}\n                  onChange={(e) => setEmail(e.target.value)}\n                  type=\"email\"\n                  name=\"Email\"\n                  className={`form-input ${classes.input}`}\n                />\n              </div>\n              <div className=\"input-container\">\n                <label htmlFor=\"Message\" className={classes.label}>\n                  Message\n                </label>\n                <textarea\n                  placeholder=\"Type your message....\"\n                  value={message}\n                  onChange={(e) => setMessage(e.target.value)}\n                  type=\"text\"\n                  name=\"Message\"\n                  className={`form-message ${classes.message}`}\n                />\n              </div>\n\n              <div className=\"submit-btn\">\n                <button type=\"submit\" className={classes.submitBtn}>\n                  <p>{!success ? \"Send\" : \"Sent\"}</p>\n                  <div className=\"submit-icon\">\n                    <AiOutlineSend\n                      className=\"send-icon\"\n                      style={{\n                        animation: !success\n                          ? \"initial\"\n                          : \"fly 0.8s linear both\",\n                        position: success ? \"absolute\" : \"initial\",\n                      }}\n                    />\n                    <AiOutlineCheckCircle\n                      className=\"success-icon\"\n                      style={{\n                        display: !success ? \"none\" : \"inline-flex\",\n                        opacity: !success ? \"0\" : \"1\",\n                      }}\n                    />\n                  </div>\n                </button>\n              </div>\n            </form>\n            <Snackbar\n              anchorOrigin={{\n                vertical: \"top\",\n                horizontal: \"center\",\n              }}\n              open={open}\n              autoHideDuration={4000}\n              onClose={handleClose}\n            >\n              <SnackbarContent\n                action={\n                  <React.Fragment>\n                    <IconButton\n                      size=\"small\"\n                      aria-label=\"close\"\n                      color=\"inherit\"\n                      onClick={handleClose}\n                    >\n                      <CloseIcon fontSize=\"small\" />\n                    </IconButton>\n                  </React.Fragment>\n                }\n                style={{\n                  backgroundColor: theme.primary,\n                  color: theme.secondary,\n                  fontFamily: \"var(--primaryFont)\",\n                }}\n                message={errMsg}\n              />\n            </Snackbar>\n          </div>\n\n          <div className=\"contacts-details\">\n            <a\n              href={`mailto:${contactsData.email}`}\n              className=\"personal-details\"\n            >\n              <div className={classes.detailsIcon}>\n                <FiAtSign />\n              </div>\n              <p style={{ color: theme.tertiary }}>{contactsData.email}</p>\n            </a>\n            <a href={`tel:${contactsData.phone}`} className=\"personal-details\">\n              <div className={classes.detailsIcon}>\n                <FiPhone />\n              </div>\n              <p style={{ color: theme.tertiary }}>{contactsData.phone}</p>\n            </a>\n            <div className=\"personal-details\">\n              <div className={classes.detailsIcon}>\n                <HiOutlineLocationMarker />\n              </div>\n              <p style={{ color: theme.tertiary }}>{contactsData.address}</p>\n            </div>\n\n            <div className=\"socialmedia-icons\">\n              {socialsData.twitter && (\n                <a\n                  href={socialsData.twitter}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaTwitter aria-label=\"Twitter\" />\n                </a>\n              )}\n              {socialsData.github && (\n                <a\n                  href={socialsData.github}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaGithub aria-label=\"GitHub\" />\n                </a>\n              )}\n              {socialsData.linkedIn && (\n                <a\n                  href={socialsData.linkedIn}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaLinkedinIn aria-label=\"LinkedIn\" />\n                </a>\n              )}\n              {socialsData.instagram && (\n                <a\n                  href={socialsData.instagram}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaInstagram aria-label=\"Instagram\" />\n                </a>\n              )}\n              {socialsData.medium && (\n                <a\n                  href={socialsData.medium}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaMediumM aria-label=\"Medium\" />\n                </a>\n              )}\n              {socialsData.blogger && (\n                <a\n                  href={socialsData.blogger}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaBloggerB aria-label=\"Blogger\" />\n                </a>\n              )}\n              {socialsData.youtube && (\n                <a\n                  href={socialsData.youtube}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaYoutube aria-label=\"YouTube\" />\n                </a>\n              )}\n              {socialsData.reddit && (\n                <a\n                  href={socialsData.reddit}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaRedditAlien aria-label=\"Reddit\" />\n                </a>\n              )}\n              {socialsData.stackOverflow && (\n                <a\n                  href={socialsData.stackOverflow}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaStackOverflow aria-label=\"Stack Overflow\" />\n                </a>\n              )}\n              {socialsData.codepen && (\n                <a\n                  href={socialsData.codepen}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaCodepen aria-label=\"CodePen\" />\n                </a>\n              )}\n              {socialsData.gitlab && (\n                <a\n                  href={socialsData.gitlab}\n                  target=\"_blank\"\n                  rel=\"noreferrer\"\n                  className={classes.socialIcon}\n                >\n                  <FaGitlab aria-label=\"GitLab\" />\n                </a>\n              )}\n            </div>\n          </div>\n        </div>\n      </div>\n      <img src={theme.contactsimg} alt=\"contacts\" className=\"contacts--img\" />\n    </div>\n  );\n}\n\nexport default Contacts;\n","/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Achievement/Achievement.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/BackToTop/BackToTop.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/pages/Main/Main.js",["190"],"import React from 'react'\nimport { Helmet } from 'react-helmet'\n\nimport { Navbar, Footer, Landing, About, Skills, Testimonials, Blog, Education, Experience, Contacts, Projects, Services, Achievement } from '../../components'\nimport { headerData } from '../../data/headerData'\n\nfunction Main() {\n    return (\n        <div>\n            <Helmet>\n                <title>{headerData.name} - Porfolio</title>\n            </Helmet>\n\n            <Navbar />        \n            <Landing />\n            <About />\n            <Education />\n            <Skills />\n            <Experience />\n            <Projects />\n            <Achievement />\n            <Services />\n            <Testimonials />\n            {/* <Blog /> */}\n            <Contacts />\n            <Footer />\n        </div>\n    )\n}\n\nexport default Main\n","/Users/bharathchowdary/Downloads/developer-portfolio-master/src/pages/Project/ProjectPage.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/theme/images.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/headerData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/skillsData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/aboutData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/utils/skillsImage.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/blogData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/socialsData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/educationData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Experience/ExperienceCard.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/projectsData.js",["191","192"],"import one from '../assets/svg/projects/one.svg'\nimport two from '../assets/svg/projects/two.svg'\nimport three from '../assets/svg/projects/three.svg'\nimport four from '../assets/svg/projects/four.svg'\nimport five from '../assets/svg/projects/five.svg'\nimport six from '../assets/svg/projects/six.svg'\nimport seven from '../assets/svg/projects/seven.svg'\nimport eight from '../assets/svg/projects/eight.svg'\n\n\nexport const projectsData = [\n    {\n        id: 1,\n        projectName: 'Messaging Application',\n        projectDesc: 'Experience seamless real-time messaging with our Spring-powered chat app.',\n        tags: ['RabbitMQ','Redis','WebSocket'],\n        code: 'https://github.com/BharathChavala1/Messaging_App.git',\n        demo: 'https://github.com/BharathChavala1/Messaging_App.git',\n        image: one\n    },\n    {\n        id: 2,\n        projectName: 'Food Delivery API',\n        projectDesc: 'Power your food delivery service with our robust API, enabling seamless ordering, tracking, and delivery management for restaurants and delivery partners',\n        tags: ['Java','Spring Boot','MySQL'],\n        code: 'https://github.com/BharathChavala1/Food_Devlivery_Project.git',\n        demo: 'https://github.com/BharathChavala1/Food_Devlivery_Project.git',\n        image: two\n    },\n    {\n        id: 3,\n        projectName: 'E-Commerce Microservice Architecture',\n        projectDesc: 'This project outlines a microservices architecture for an e-commerce platform. The system utilizes Docker containers orchestrated by Kubernetes for deployment and management.',\n        tags: ['Microservice Architecture','Kafka','Docker','Grafana'],\n        code: 'https://github.com/BharathChavala1/E-Commerce-Microservice-Architecture.git',\n        demo: 'https://github.com/BharathChavala1/E-Commerce-Microservice-Architecture.git',\n        image: three\n    },\n    {\n        id: 4,\n        projectName: 'E-Commerce App',\n        projectDesc: 'A simple User Friendly E-commerce application',\n        tags: ['Spring Data JPA', 'Hibernate','MySQL'],\n        code: 'https://github.com/BharathChavala1/E-Commerce.git',\n        demo: 'https://github.com/BharathChavala1/E-Commerce.git',\n        image: four\n    },\n    {\n        id: 5,\n        projectName: 'Spring Boot Employee Data Management System',\n        projectDesc: 'A Spring Boot application for managing employee data with RESTful APIs, using lambda expressions for efficient data processing and external service integration.',\n        tags: ['Java', 'Spring Boot', 'MySQL', 'Spring Data JPA'],\n        code: 'https://github.com/BharathChavala1/Spring-Employee-Project.git',\n        demo: 'https://github.com/BharathChavala1/Spring-Employee-Project.git',\n        image: five\n    },\n    {\n        id: 6,\n        projectName: 'Order Management with Redis Caching and Pub/Sub',\n        projectDesc: 'A Spring-based Order Management system using Redis for efficient caching and real-time Pub/Sub messaging, enhancing performance and enabling instant order updates across services.',\n        tags: ['Spring Boot','Java','Redis','Spring MVC'],\n        code: 'https://github.com/hhhrrrttt222111/developer-portfolio',\n        demo: 'https://github.com/hhhrrrttt222111/developer-portfolio',\n        image: six\n    },\n]\n\n\n// Do not remove any fields.\n// Leave it blank instead as shown below\n\n/* \n{\n    id: 1,\n    projectName: 'Car Pooling System',\n    projectDesc: '',\n    tags: ['Flutter', 'React'],\n    code: '',\n    demo: '',\n    image: ''\n}, \n*/","/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Education/EducationCard.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/servicesData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/experienceData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/testimonialsData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/components/Achievement/AchievementCard.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/achievementData.js",[],"/Users/bharathchowdary/Downloads/developer-portfolio-master/src/data/contactsData.js",[],{"ruleId":"193","severity":1,"message":"194","line":131,"column":10,"nodeType":"195","messageId":"196","endLine":131,"endColumn":19},{"ruleId":"193","severity":1,"message":"197","line":4,"column":64,"nodeType":"195","messageId":"196","endLine":4,"endColumn":68},{"ruleId":"193","severity":1,"message":"198","line":7,"column":8,"nodeType":"195","messageId":"196","endLine":7,"endColumn":13},{"ruleId":"193","severity":1,"message":"199","line":8,"column":8,"nodeType":"195","messageId":"196","endLine":8,"endColumn":13},"no-unused-vars","'isLoading' is assigned a value but never used.","Identifier","unusedVar","'Blog' is defined but never used.","'seven' is defined but never used.","'eight' is defined but never used."]